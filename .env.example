# ══════════════════════════════════════════════════════════════════════════════
# PantheonMed AI — Environment Configuration Template
# ══════════════════════════════════════════════════════════════════════════════
# 1. Copy this file:   cp .env.example .env
# 2. Fill in values    (search for CHANGE_ME)
# 3. NEVER commit .env to git — it is already in .gitignore
#
# Legend:
#   [REQUIRED]  Must be set before the app will start in production
#   [OPTIONAL]  Has a safe default — set for enhanced functionality
#   [DEV ONLY]  Used in development only, ignored in production
# ══════════════════════════════════════════════════════════════════════════════


# ── Application ───────────────────────────────────────────────────────────────
# [REQUIRED] "development" | "production"
ENV=development

# [REQUIRED] Set to false in production (disables Swagger UI and tracebacks)
DEBUG=true


# ── Security ──────────────────────────────────────────────────────────────────
# [REQUIRED] Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE_ME-USE-64-CHAR-RANDOM-STRING-IN-PRODUCTION

# [OPTIONAL] JWT access token lifetime in minutes (default: 30)
# Backend reads JWT_ACCESS_EXPIRE_MINUTES (not ACCESS_TOKEN_EXPIRE_MINUTES)
JWT_ACCESS_EXPIRE_MINUTES=1440


# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# [REQUIRED] Use a strong password in production (no special chars that break URLs)
POSTGRES_PASSWORD=pantheon_dev_2024

# [OPTIONAL] Override only when connecting to an external/managed DB
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/pantheonmed


# ── Redis ─────────────────────────────────────────────────────────────────────
# [REQUIRED] Use a strong password in production
REDIS_PASSWORD=redis_dev_2024

# [OPTIONAL] Cache TTL in seconds (default: 1 hour)
CACHE_TTL=3600

# [OPTIONAL] Full Redis URL when using password locally
# Docker sets this automatically. For local Redis with password:
# REDIS_URL=redis://:your_password@localhost:6379/0


# ── AI Providers — set at least one ───────────────────────────────────────────
# [REQUIRED] Primary AI engine: "gemini" | "openai" | "anthropic"
AI_PROVIDER=gemini

# Google Gemini (recommended — has free tier, fastest)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# OpenAI (alternative)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (alternative)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-haiku-4-5-20251001


# ── External Medical APIs (optional — enhances RAG responses) ─────────────────
# FDA OpenFDA: free, no key required for basic use
# PubMed:      free, no key required for basic use
# UMLS:        free registration at https://uts.nlm.nih.gov/uts/umls/home
UMLS_API_KEY=


# ── CORS & Frontend ───────────────────────────────────────────────────────────
# [REQUIRED for production] Comma-separated list of allowed frontend origins
# Example: https://app.pantheonmed.ai,https://www.pantheonmed.ai
ALLOWED_ORIGINS_PROD=

# [REQUIRED] Public URL of the backend API (used by Next.js at build time)
# Development: http://localhost:8000
# Production:  https://your-domain.com/api  (if Nginx proxies /api → backend)
#              OR https://api.your-domain.com (if backend has its own subdomain)
NEXT_PUBLIC_API_URL=http://localhost:8000


# ── Admin Seed Account ────────────────────────────────────────────────────────
# [REQUIRED] Created automatically on first startup. Change immediately after login.
ADMIN_EMAIL=admin@pantheonmed.ai
ADMIN_PASSWORD=ChangeMe123!


# ── Rate Limiting ─────────────────────────────────────────────────────────────
# [OPTIONAL] Requests per minute per IP
RATE_LIMIT_PER_MINUTE=60
AI_RATE_LIMIT_PER_MINUTE=20
LOGIN_RATE_LIMIT_PER_MINUTE=5


# ── Production / Nginx ────────────────────────────────────────────────────────
# [REQUIRED for production] Your public domain (used by docker-compose.prod.yml)
DOMAIN=your-domain.com

# [REQUIRED for production] Email for Let's Encrypt TLS certificate
CERTBOT_EMAIL=admin@your-domain.com


# ── Observability (optional) ──────────────────────────────────────────────────
# Sentry — error tracking (https://sentry.io)
SENTRY_DSN=

# OpenTelemetry — distributed tracing
OTEL_EXPORTER_OTLP_ENDPOINT=


# ── File Uploads ──────────────────────────────────────────────────────────────
# [OPTIONAL] Max upload size in megabytes (default: 20 MB)
MAX_UPLOAD_MB=20
