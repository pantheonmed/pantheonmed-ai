# PantheonMed AI — Frontend Environment

# Backend URL. When unset, the frontend uses relative /api/v1 and Next.js proxies
# to http://localhost:8000 (avoids CORS). Set this when the backend runs elsewhere.
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: paste JWT token here for development
NEXT_PUBLIC_API_TOKEN=PASTE_TOKEN_HERE
