# ══════════════════════════════════════════════════════════════════════════════
# PantheonMed AI — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Secrets & Environment ─────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.*.local
*.pem
*.key
secrets/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
# Exception: frontend src/lib (auth, utils) must be committed
!pantheonmed-ai-frontend/src/lib/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
ENV/
env/
.env.backup

# ── pytest / testing ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.coveragerc
.tox/

# ── Node.js / Next.js ─────────────────────────────────────────────────────────
node_modules/
.next/
out/
.nuxt/
dist/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Database ──────────────────────────────────────────────────────────────────
*.sqlite3
*.db

# ── Uploads / user data ───────────────────────────────────────────────────────
backend/uploads/
*.pdf
*.jpg
*.jpeg
*.png
!public/**/*.png
!public/**/*.jpg

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
!logs/.gitkeep

# ── Docker ────────────────────────────────────────────────────────────────────
# (Keep docker-compose.yml but not overrides with secrets)
docker-compose.override.yml
docker-compose.prod.override.yml

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
*.iml

# ── Alembic ───────────────────────────────────────────────────────────────────
# Keep migration files, ignore auto-generated temp files
backend/alembic/versions/__pycache__/
